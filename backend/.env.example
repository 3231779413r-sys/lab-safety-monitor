# Lab Safety Backend Configuration
# Copy this file to .env and modify values for your machine.
# Do not commit production secrets.

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=True
APP_ENV=dev
SQL_ECHO=false
APP_NAME=碳丝聚合车间操作人员危险行为识别系统
BACKEND_MODE=all

# =============================================================================
# Database
# =============================================================================
# PostgreSQL is recommended for production and multi-user testing.
DATABASE_URL=postgresql+asyncpg://postgres:your-password@localhost:5432/sentinelvision

# SQLite is suitable only for lightweight local development.
# DATABASE_URL=sqlite+aiosqlite:///./sentinelvision.db

# =============================================================================
# API Settings
# =============================================================================
# Allowed frontend origins. Keep this JSON-array format.
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002"]

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
WORKER_INTERNAL_BASE_URL=http://monitor-worker:8001
WORKER_INTERNAL_TOKEN=change-this-worker-token
WORKER_INTERNAL_TIMEOUT_SECONDS=60
PG_NOTIFY_CHANNEL=lab_safety_realtime
INIT_ADMIN_ENABLED=true
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=Admin123456
INIT_ADMIN_FULL_NAME=系统管理员

# =============================================================================
# ML Model Settings
# =============================================================================
DETECTION_CONFIDENCE_THRESHOLD=0.5
VIOLATION_CONFIDENCE_THRESHOLD=0.3
FACE_RECOGNITION_THRESHOLD=0.45
FACE_RECOGNITION_MIN_DETECTION_SCORE=0.6
FACE_RECOGNITION_MIN_MARGIN=0.05
FACE_IDENTITY_CACHE_TTL_SECONDS=8
FACE_IDENTITY_REFRESH_INTERVAL_FRAMES=8
REID_FEATURE_TTL_SECONDS=7200

# Mock mode uses fake detections without loading ML models.
USE_MOCK_DETECTOR=false
USE_MOCK_FACE=false

# =============================================================================
# Pose Estimation
# =============================================================================
USE_POSE_ESTIMATION=false
POSE_CONFIDENCE_THRESHOLD=0.4
POSE_IOU_THRESHOLD=0.3
POSE_RUN_INTERVAL=1
POSE_KEYPOINT_CONFIDENCE_THRESHOLD=0.35
POSE_ACTION_LABELS_ENABLED=true
POSE_SHOW_NEUTRAL_STATUS=false
POSE_ACTION_MIN_FRAMES=2
POSE_ACTION_CLEAR_FRAMES=2
POSE_HAND_MOUTH_DISTANCE_RATIO=0.18
POSE_FALL_ASPECT_RATIO=1.25
POSE_BENDING_ANGLE_DEG=35.0

# =============================================================================
# SAM Segmentation Model
# =============================================================================
# If HuggingFace access is unavailable, keep USE_SAM3=false and use local SAM2.
USE_SAM3=false
SAM3_MODEL_PATH=./weights/sam3/sam3.pt

USE_SAM2=true
SAM2_MODEL_PATH=./weights/sam2/sam2.1_hiera_base_plus.pt
USE_SAM2_VIDEO_PROPAGATION=false
SAM2_PROPAGATE_INTERVAL=2
SAM2_SEGMENT_PPE=true

# =============================================================================
# PPE Detection Model
# =============================================================================
YOLOV11_MODEL_PATH=./weights/ppe_detector/YOLOv8 Finetuning for PPE detection.pt

# Required PPE items. Keep values aligned with model labels and formatter mapping.
# Available examples: goggles, mask, gloves, hardhat, safety_vest, lab_coat, head_mask
# REQUIRED_PPE=goggles,mask,hardhat,safety_vest

# =============================================================================
# Temporal Filtering
# =============================================================================
FRAME_SAMPLE_RATE=10
TEMPORAL_BUFFER_SIZE=3
TEMPORAL_FUSION_STRATEGY=ema
TEMPORAL_EMA_ALPHA=0.7
TEMPORAL_CONFIDENCE_THRESHOLD=0.4
TEMPORAL_VIOLATION_MIN_FRAMES=2
TEMPORAL_VIOLATION_MIN_FRAMES_CLEAR=3

# =============================================================================
# Live Stream Performance
# =============================================================================
# Browser MJPEG output frame rate.
LIVE_STREAM_DISPLAY_FPS=25

# AI processing target fps per camera. Increase carefully.
LIVE_STREAM_PROCESS_FPS=5

# Latest-frame queue size for processing.
LIVE_STREAM_QUEUE_SIZE=2

# Optional bbox interpolation.
LIVE_STREAM_INTERPOLATE=false

# Always-on camera monitoring.
CAMERA_MONITOR_AUTO_START=true
CAMERA_MONITOR_RECONNECT_SECONDS=5
CAMERA_MONITOR_MAX_CAMERAS=4
CAMERA_MONITOR_DISPLAY_FPS=25
PERSON_LAST_SEEN_UPDATE_SECONDS=30

# RTSP fallback settings.
CAMERA_RTSP_TRANSPORT=tcp
CAMERA_RTSP_OPEN_TIMEOUT_MS=5000
CAMERA_RTSP_READ_FAILURE_THRESHOLD=5

# Capture backend: hikvision_sdk or rtsp.
CAMERA_CAPTURE_BACKEND=hikvision_sdk
HIKVISION_SDK_DIR=/opt/hikvision/HCNetSDK/lib
HIKVISION_SDK_PORT=8000

# =============================================================================
# Multi-Scale Detection
# =============================================================================
MULTI_SCALE_ENABLED=true
MULTI_SCALE_FACTORS=[1.0,1.5,2.0]
MULTI_SCALE_NMS_THRESHOLD=0.5

# =============================================================================
# Mask Display
# =============================================================================
SHOW_MASKS=true
MASK_ALPHA=0.4
MASK_DENSITY_THRESHOLD=0.1
MASK_CONTAINMENT_THRESHOLD=0.5

# =============================================================================
# Snapshot Capture
# =============================================================================
ENABLE_SNAPSHOT_CAPTURE=true
LOGS_DIR=./logs

# =============================================================================
# MinIO Snapshot Storage
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lab-safety-monitor
MINIO_VIDEO_BUCKET=lab-safety-videos
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=3600
